// Prisma schema for ArrowMaze backend.
// DB: PostgreSQL (hosted on Supabase). Set DATABASE_URL in .env.
// Workflow: `npx prisma generate` after install, `npx prisma migrate dev` for schema changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Nivel {
  id              String      @id @default(uuid()) @db.Uuid
  nombre          String
  dificultad      String
  ancho           Int
  alto            Int
  baseNivel       Int         @map("base_nivel")
  kmov            Int
  ktiempo         Int
  umbralEstrella1 Int         @map("umbral_estrella_1")
  umbralEstrella2 Int         @map("umbral_estrella_2")
  umbralEstrella3 Int         @map("umbral_estrella_3")
  limiteTiempo    Int?        @map("limite_tiempo")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  celdas          CeldaNivel[]

  @@map("niveles")
}

model CeldaNivel {
  id        String @id @default(uuid()) @db.Uuid
  nivelId   String @map("nivel_id") @db.Uuid
  x         Int
  y         Int
  tipo      String
  direccion String?
  nivel     Nivel  @relation(fields: [nivelId], references: [id], onDelete: Cascade)

  @@map("celdas_nivel")
}
